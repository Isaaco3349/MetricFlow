{
  "compilerOptions": {
    "target": "ES2021",
    "module": "NodeNext",
"moduleResolution": "NodeNext",
    "lib": ["ES2021", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": []
  },
  "include": ["src/**/*"],
  "skipLibCheck": true,
"noEmit": false,
"exclude": ["node_modules/**", "dist", "**/*.d.ts"]
}